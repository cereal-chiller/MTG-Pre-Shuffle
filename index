<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Commander Deck Weaver</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body { background-color: #0f172a; color: #f8fafc; }
    </style>
</head>
<body class="p-4 md:p-6 font-sans flex flex-col min-h-screen">

    <div class="max-w-4xl mx-auto flex-grow w-full">
        <header class="mb-8 text-center border-b border-slate-800 pb-6">
            <h1 class="text-3xl font-extrabold text-indigo-400">EDH Pre-Shuffle Weaver</h1>
            <p class="text-slate-400 text-sm mt-2">Input your card counts to get an evenly interleaved layout order before your final match.</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            
            <!-- INPUT COLUMN -->
            <div class="md:col-span-1 bg-slate-900 p-5 rounded-xl border border-slate-800 h-fit shadow-xl">
                <h2 class="text-lg font-bold mb-4 text-indigo-300">Card Counts</h2>
                <div id="inputsContainer" class="space-y-3">
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 mb-1">Lands</label>
                        <input type="number" id="count-Land" value="36" min="0" class="w-full bg-slate-800 border border-slate-700 rounded p-2 text-white text-sm focus:outline-none focus:border-indigo-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 mb-1">Creatures</label>
                        <input type="number" id="count-Creature" value="30" min="0" class="w-full bg-slate-800 border border-slate-700 rounded p-2 text-white text-sm focus:outline-none focus:border-indigo-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 mb-1">Artifacts / Mana Rocks</label>
                        <input type="number" id="count-Artifact" value="12" min="0" class="w-full bg-slate-800 border border-slate-700 rounded p-2 text-white text-sm focus:outline-none focus:border-indigo-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 mb-1">Enchantments</label>
                        <input type="number" id="count-Enchantment" value="10" min="0" class="w-full bg-slate-800 border border-slate-700 rounded p-2 text-white text-sm focus:outline-none focus:border-indigo-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 mb-1">Instants / Sorceries</label>
                        <input type="number" id="count-Spells" value="11" min="0" class="w-full bg-slate-800 border border-slate-700 rounded p-2 text-white text-sm focus:outline-none focus:border-indigo-500">
                    </div>
                </div>

                <div class="mt-4 pt-4 border-t border-slate-800">
                    <div class="text-sm font-medium text-slate-400 mb-2 flex justify-between">
                        <span>Total Maindeck:</span>
                        <span id="totalCount" class="font-bold text-white">99</span>
                    </div>
                    <button id="generateBtn" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded transition text-sm shadow-lg shadow-indigo-900/40 cursor-pointer">
                        Generate Layout Guide
                    </button>
                </div>
            </div>

            <!-- OUTPUT COLUMN -->
            <div class="md:col-span-2 bg-slate-900 p-5 rounded-xl border border-slate-800 shadow-xl">
                <h2 class="text-lg font-bold mb-2 text-emerald-400">Your Layout Sequence</h2>
                <p class="text-xs text-slate-400 mb-4">Separate your cards into physical type piles, then lay them face down one-by-one following this pattern:</p>
                
                <div id="outputGuide" class="space-y-3 max-h-[60vh] overflow-y-auto pr-2">
                    <p class="text-slate-500 italic text-sm">Click "Generate Layout Guide" to build your pattern.</p>
                </div>
            </div>

        </div>
    </div>

    <!-- SUPPORTER FOOTER -->
    <footer class="mt-12 text-center text-xs text-slate-500 border-t border-slate-800/60 pt-6 pb-4 w-full max-w-4xl mx-auto">
        <p>EDH Pre-Shuffle Weaver is a free utility tool for Magic: The Gathering players.</p>
        <p class="mt-1 text-slate-600">This tool is not affiliated with Wizards of the Coast.</p>
        <div class="mt-4">
            <!-- Replace the link below with your personal Ko-fi or Buy Me A Coffee URL -->
            <a href="https://ko-fi.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center space-x-2 bg-amber-600 hover:bg-amber-700 text-white font-bold py-1.5 px-4 rounded-full transition shadow-md text-xs tracking-wide">
                <span>☕</span>
                <span>Support This Project</span>
            </a>
        </div>
    </footer>

    <script>
        const types = ['Land', 'Creature', 'Artifact', 'Enchantment', 'Spells'];
        const colors = {
            'Land': 'bg-amber-950/30 border-amber-800/50 text-amber-300',
            'Creature': 'bg-emerald-950/30 border-emerald-800/50 text-emerald-300',
            'Artifact': 'bg-slate-800/50 border-slate-700 text-slate-300',
            'Enchantment': 'bg-purple-950/30 border-purple-800/50 text-purple-300',
            'Spells': 'bg-sky-950/30 border-sky-800/50 text-sky-300'
        };

        const inputs = types.map(t => document.getElementById(`count-${t}`));
        const totalCountSpan = document.getElementById('totalCount');
        const generateBtn = document.getElementById('generateBtn');
        const outputGuide = document.getElementById('outputGuide');

        function updateTotal() {
            let total = 0;
            inputs.forEach(input => total += parseInt(input.value) || 0);
            totalCountSpan.textContent = total;
            if(total === 99) {
                totalCountSpan.className = "font-bold text-emerald-400";
            } else {
                totalCountSpan.className = "font-bold text-amber-400";
            }
        }

        inputs.forEach(input => input.addEventListener('input', updateTotal));
        updateTotal();

        generateBtn.addEventListener('click', () => {
            let dataset = [];
            let totalCards = 0;

            types.forEach(type => {
                let count = parseInt(document.getElementById(`count-${type}`).value) || 0;
                if (count > 0) {
                    dataset.push({ type, count, accumulator: 0 });
                    totalCards += count;
                }
            });

            if (totalCards === 0) {
                outputGuide.innerHTML = '<p class="text-rose-400 italic text-sm">Please enter at least one card quantity.</p>';
                return;
            }

            let sequence = [];
            for (let i = 0; i < totalCards; i++) {
                dataset.forEach(item => item.accumulator += item.count);
                let choice = dataset.reduce((max, item) => item.accumulator > max.accumulator ? item : max, dataset[0]);
                sequence.push(choice.type);
                choice.accumulator -= totalCards;
            }

            let compressed = [];
            let currentType = sequence[0];
            let currentCount = 1;

            for (let i = 1; i < sequence.length; i++) {
                if (sequence[i] === currentType) {
                    currentCount++;
                } else {
                    compressed.push({ type: currentType, count: currentCount });
                    currentType = sequence[i];
                    currentCount = 1;
                }
            }
            compressed.push({ type: currentType, count: currentCount });

            outputGuide.innerHTML = '';
            compressed.forEach((block, index) => {
                let colorClass = colors[block.type] || 'bg-slate-800 border-slate-700 text-slate-300';
                outputGuide.innerHTML += `
                    <div class="flex items-center justify-between border p-3 rounded-lg ${colorClass} shadow-sm transition hover:scale-[1.01]">
                        <div class="flex items-center space-x-3">
                            <span class="text-xs opacity-40 font-mono">Step ${String(index + 1).padStart(2, '0')}</span>
                            <span class="font-bold text-sm md:text-base">Lay down: ${block.count} × ${block.type}${block.count > 1 ? 's' : ''}</span>
                        </div>
                        <span class="text-[10px] uppercase tracking-wider px-2 py-0.5 rounded bg-black/30 font-mono hidden sm:inline">Next Pile</span>
                    </div>
                `;
            });
            
            outputGuide.innerHTML += `
                <div class="text-center p-4 bg-slate-800/30 rounded-lg border border-dashed border-slate-700 mt-4">
                    <p class="text-sm text-emerald-400 font-semibold">🎉 All ${totalCards} cards distributed!</p>
                    <p class="text-xs text-slate-500 mt-1">Gather the cards up into a single stack and proceed with your standard shuffling routines.</p>
                </div>
            `;
        });
    </script>
</body>
</html>
